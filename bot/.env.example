# ── Token du bot (Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=ton_token_ici

# ── Secret partagé avec l'app web (invente un mot de passe fort)
APP_SECRET=un_mot_de_passe_tres_long_et_aleatoire

# ── ID de ton serveur Discord (clic droit sur le serveur → Copier l'identifiant)
GUILD_ID=ton_guild_id_ici

# ── ID du canal de photos par défaut (optionnel)
# Si défini, l'app peut requêter /channel-images sans préciser channelId.
# L'app peut aussi choisir n'importe quel autre canal via le dropdown.
# IMPORTANT : le bot a besoin de l'intent privilégié "Message Content" activé
# dans Discord Developer Portal → Bot → Privileged Gateway Intents.
PHOTO_CHANNEL_ID=ton_channel_photos_par_defaut_ici

# ── Relay des tweets X vers un canal Discord (optionnel)
# URL d'un flux RSS qui représente le compte X de l'asso.
# Options :
#   - RSSHub public  : https://rsshub.app/twitter/user/<handle>   (gratuit, fragile)
#   - rss.app payant : https://rss.app/feeds/.../...xml           (~9$/mois, stable)
#   - tout autre flux RSS qui sort des items <link> avec des URLs twitter.com / x.com
TWEETS_RSS_URL=
# Canal Discord où poster les nouveaux tweets
TWEETS_CHANNEL_ID=
# Intervalle de polling en minutes (défaut 15)
TWEETS_POLL_MINUTES=15

# ── Rôles "TO FG" et "TO Smash" pour les résultats horaires (optionnel)
# Si définis, /horaires-results annote chaque votant avec sa membership de
# ces rôles, et l'app affiche 2 sections supplémentaires "TO FG" / "TO Smash".
# Pour récupérer un ID de rôle : Discord → mode développeur → clic droit sur
# le rôle dans la liste des membres → "Copier l'identifiant".
TO_FG_ROLE_ID=
TO_SMASH_ROLE_ID=

# ── Port (Railway le définit automatiquement, ne pas changer)
PORT=3000
