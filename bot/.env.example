# ── Token du bot (Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=ton_token_ici

# ── Secret partagé avec l'app web (invente un mot de passe fort)
APP_SECRET=un_mot_de_passe_tres_long_et_aleatoire

# ── ID de ton serveur Discord (clic droit sur le serveur → Copier l'identifiant)
GUILD_ID=ton_guild_id_ici

# ── Port (Railway le définit automatiquement, ne pas changer)
PORT=3000
